{
  "name": "@agent-x/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:promote-admin": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@agent-x/shared": "workspace:*",
    "@ai-sdk/alibaba": "^1.0.8",
    "@ai-sdk/anthropic": "^3.0.53",
    "@ai-sdk/deepseek": "^2.0.22",
    "@ai-sdk/google": "^3.0.36",
    "@ai-sdk/mcp": "^1.0.23",
    "@ai-sdk/moonshotai": "^2.0.8",
    "@ai-sdk/openai": "^3.0.39",
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/jwt": "^11",
    "@nestjs/platform-express": "^11",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-node": "^2.5.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "ai": "^6.0.108",
    "archiver": "^7.0.1",
    "bcryptjs": "^2",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "dotenv": "^17.3.1",
    "mime-types": "^3.0.2",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "zhipu-ai-provider": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@nestjs/testing": "^11",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2",
    "@types/express": "^5",
    "@types/jest": "^29",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22",
    "eslint": "^9.21.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.15.0",
    "jest": "^29",
    "prisma": "^7.4.2",
    "ts-jest": "^29",
    "ts-node": "^10",
    "typescript": "^5.7",
    "typescript-eslint": "^8.24.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
