generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  providers     Provider[]
  agents        Agent[]
  apiKeys       ApiKey[]
  conversations Conversation[]
  preferences   UserPreferences?
}

enum UserRole {
  ADMIN
  USER
}

enum ProviderProtocol {
  OPENAI
  ANTHROPIC
  GEMINI
  DEEPSEEK
  QWEN
  ZHIPU
  MOONSHOT
}

model Provider {
  id        String           @id @default(cuid())
  userId    String
  name      String
  protocol  ProviderProtocol
  baseUrl   String
  apiKey    String
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user          User            @relation(fields: [userId], references: [id])
  models        ProviderModel[]
  agents        Agent[]
  agentVersions AgentVersion[]
}

model ProviderModel {
  id         String  @id @default(cuid())
  providerId String
  modelId    String
  name       String
  isActive   Boolean @default(true)

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, modelId])
}

enum AgentStatus {
  ACTIVE
  ARCHIVED
}

model Agent {
  id           String      @id @default(cuid())
  userId       String
  providerId   String
  modelId      String
  name         String
  description  String?
  avatar       String?
  systemPrompt String
  temperature  Float       @default(0.7)
  maxTokens    Int         @default(4096)
  status       AgentStatus @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  user          User           @relation(fields: [userId], references: [id])
  provider      Provider       @relation(fields: [providerId], references: [id])
  skills        AgentSkill[]
  mcpServers    AgentMcp[]
  conversations Conversation[]
  apiKeys       ApiKey[]
  versions      AgentVersion[]
}

enum McpType {
  OFFICIAL
  CUSTOM
}

enum McpTransport {
  STDIO
  SSE
  STREAMABLE_HTTP
}

model McpServer {
  id          String       @id @default(cuid())
  name        String
  description String?
  type        McpType
  transport   McpTransport
  config      Json
  tools       Json?
  isPublic    Boolean      @default(false)
  createdBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  agents AgentMcp[]
}

model AgentMcp {
  id           String   @id @default(cuid())
  agentId      String
  mcpServerId  String
  enabledTools String[]

  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  mcpServer McpServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)

  @@unique([agentId, mcpServerId])
}

enum SkillType {
  SYSTEM
  CUSTOM
}

model Skill {
  id          String    @id @default(cuid())
  name        String
  description String?
  content     String
  type        SkillType
  tags        String[]
  isPublic    Boolean   @default(false)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  agents AgentSkill[]
}

model AgentSkill {
  id       String @id @default(cuid())
  agentId  String
  skillId  String
  priority Int    @default(0)

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([agentId, skillId])
}

enum PromptType {
  SYSTEM
  CUSTOM
}

model PromptCategory {
  id        String     @id @default(cuid())
  name      String
  type      PromptType
  createdBy String?
  createdAt DateTime   @default(now())

  prompts Prompt[]

  @@unique([name, createdBy])
}

model Prompt {
  id          String     @id @default(cuid())
  name        String
  description String?
  content     String
  type        PromptType
  categoryId  String?
  tags        String[]
  isPublic    Boolean    @default(false)
  createdBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  category PromptCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model Conversation {
  id             String   @id @default(cuid())
  userId         String?
  agentId        String
  agentVersionId String?
  shareTokenId   String?
  title          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id])
  agent        Agent         @relation(fields: [agentId], references: [id])
  agentVersion AgentVersion? @relation(fields: [agentVersionId], references: [id])
  shareToken   ShareToken?   @relation(fields: [shareTokenId], references: [id])
  messages     Message[]
  files        WorkspaceFile[]
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  parts          Json
  metadata       Json?
  tokenUsage     Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AgentVersion {
  id                 String   @id @default(cuid())
  agentId            String
  version            Int
  providerId         String
  modelId            String
  systemPrompt       String
  temperature        Float
  maxTokens          Int
  skillsSnapshot     Json     @default("[]")
  mcpServersSnapshot Json     @default("[]")
  changelog          String?
  publishedAt        DateTime @default(now())
  createdAt          DateTime @default(now())

  agent         Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  provider      Provider       @relation(fields: [providerId], references: [id])
  shareTokens   ShareToken[]
  conversations Conversation[]

  @@unique([agentId, version])
}

model ShareToken {
  id                String    @id @default(cuid())
  agentVersionId    String
  token             String    @unique
  tokenSlug         String?
  name              String
  expiresAt         DateTime?
  maxConversations  Int?
  usedConversations Int       @default(0)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())

  agentVersion  AgentVersion   @relation(fields: [agentVersionId], references: [id], onDelete: Cascade)
  conversations Conversation[]
}

model WorkspaceFile {
  id             String   @id @default(cuid())
  conversationId String
  path           String   // e.g. "src/App.tsx"
  mimeType       String   // e.g. "text/typescript", "image/png"
  size           Int      // bytes
  isDirectory    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, path])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  agentId    String?
  key        String    @unique
  name       String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id])
  agent Agent? @relation(fields: [agentId], references: [id])
}

model UserPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  theme     String?
  language  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
