FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

FROM base AS deps
WORKDIR /app
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY packages/server/package.json packages/server/
COPY packages/shared/package.json packages/shared/
RUN pnpm install --frozen-lockfile --prod=false

FROM base AS build
WORKDIR /app
COPY --from=deps /app ./
COPY packages/shared/ packages/shared/
COPY packages/server/ packages/server/
RUN cd packages/server && npx prisma generate
RUN pnpm --filter @agent-x/server build

FROM base AS production
WORKDIR /app
COPY --from=build /app/packages/server/dist ./dist
COPY --from=build /app/packages/server/node_modules ./node_modules
COPY --from=build /app/packages/server/prisma ./prisma
COPY --from=build /app/packages/server/prisma.config.ts ./prisma.config.ts
COPY --from=build /app/packages/server/src/generated ./src/generated
COPY --from=build /app/packages/server/package.json ./package.json
EXPOSE 3000
CMD ["node", "dist/main.js"]
