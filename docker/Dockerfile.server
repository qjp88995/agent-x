FROM node:22-slim AS base
RUN apt-get update && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

FROM base AS deps
WORKDIR /app
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY packages/server/package.json packages/server/
COPY packages/shared/package.json packages/shared/
RUN pnpm install --frozen-lockfile --prod=false

FROM base AS build
WORKDIR /app
COPY --from=deps /app ./
COPY packages/shared/ packages/shared/
COPY packages/server/ packages/server/
RUN cd packages/server && npx prisma generate
RUN pnpm --filter @agent-x/server build
RUN pnpm deploy --filter @agent-x/server --prod /app/deployed

FROM node:22-slim AS production
RUN apt-get update && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*
ENV NODE_ENV=production
WORKDIR /app

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nestjs
RUN mkdir -p /app/data/workspaces && chown -R nestjs:nodejs /app/data

COPY --from=build --chown=nestjs:nodejs /app/deployed ./
COPY --from=build --chown=nestjs:nodejs /app/packages/server/dist ./dist
COPY --from=build --chown=nestjs:nodejs /app/packages/server/prisma ./prisma
COPY --from=build --chown=nestjs:nodejs /app/packages/server/prisma.config.ts ./prisma.config.ts
COPY --from=build --chown=nestjs:nodejs /app/packages/server/src/generated ./src/generated
COPY --chown=nestjs:nodejs docker/entrypoint.sh ./entrypoint.sh

USER nestjs
EXPOSE 3000
ENTRYPOINT ["./entrypoint.sh"]
