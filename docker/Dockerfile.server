FROM node:22-slim AS base
RUN apt-get update && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

FROM base AS deps
WORKDIR /app
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY packages/server/package.json packages/server/
COPY packages/shared/package.json packages/shared/
RUN pnpm install --frozen-lockfile --prod=false

FROM base AS build
WORKDIR /app
COPY --from=deps /app ./
COPY packages/shared/ packages/shared/
COPY packages/server/ packages/server/
RUN cd packages/server && DATABASE_URL=postgresql://dummy:dummy@localhost:5432/dummy npx prisma generate
RUN pnpm --filter @agent-x/server build
RUN pnpm deploy --filter @agent-x/server --prod --legacy /app/deployed
RUN cp -r /app/packages/server/dist /app/deployed/dist && \
    cp -r /app/packages/server/src/generated /app/deployed/src/generated

FROM node:22-slim AS production
RUN apt-get update && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*
ENV NODE_ENV=production
WORKDIR /app

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nestjs
RUN mkdir -p /app/data/workspaces && chown -R nestjs:nodejs /app/data

COPY --from=build --chown=nestjs:nodejs /app/deployed ./
COPY --chown=nestjs:nodejs docker/entrypoint.sh ./entrypoint.sh

USER nestjs
EXPOSE 3000
ENTRYPOINT ["./entrypoint.sh"]
