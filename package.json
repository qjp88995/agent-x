{
  "name": "agent-x",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:migrate": "pnpm --filter @agent-x/server db:migrate",
    "db:generate": "pnpm --filter @agent-x/server db:generate",
    "db:studio": "pnpm --filter @agent-x/server db:studio",
    "format": "prettier --write \"packages/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,css,json}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "turbo": "^2"
  },
  "lint-staged": {
    "packages/web/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix -c packages/web/eslint.config.js"
    ],
    "packages/server/**/*.ts": [
      "prettier --write",
      "eslint --fix -c packages/server/eslint.config.mjs"
    ],
    "packages/shared/**/*.ts": [
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.0"
}
